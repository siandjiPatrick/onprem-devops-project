{"version":4,"terraform_version":"1.10.3","serial":79,"lineage":"63347ea7-7868-7eda-f05b-7b2f5805cdc0","outputs":{},"resources":[{"mode":"data","type":"template_file","name":"cloudinit","provider":"provider[\"registry.opentofu.org/hashicorp/template\"]","instances":[{"schema_version":0,"attributes":{"filename":null,"id":"78830369915eb14f0eb474632c4adccb4a64e3ac75c68be24b1e8d033f490f18","rendered":"#cloud-config\n#https://cloudinit.readthedocs.io/en/latest/reference/examples.html\n\nmanage_etc_hosts: true\npackage_update: true\npackage_upgrade: true\n\nhostname: cloudinit_server\nfqdn: cloudinit_server.devops-infra.local\npreserve_hostname: false\n\nssh_pwauth: true\nusers: \n   - name: patrick\n     sudo: ALL=(ALL) NOPASSWD:ALL\n     groups: users, admin\n     home: /home/patrick\n     shell: /bin/bash\n     lock_passwd: false\n     passwd: $6$lVRqiAwCHdiky0Vp$WdiRM0VToJKGPXSvj1ioRirRBYHB7tJADEzPOfRyG1PfVOiR.lmvzPf4n0W5vFxqONqxpcrtYd0hEAxJuT2xX0\n     ssh_authorized_keys: \n       - ssh-rsa  patrick@patrick-ubuntu-legion\n    \n\npackages: \n   - python3\n   - python3-pip\n   - apache2-utils\n   - vim\n   - docker.io\n   - eatmydata\n   - cockpit\n   - cockpit-machines\n   - fail2ban\n   - ufw\n   - htop\n   - iftop\n   - nmap\n   - net-tools\n   - curl\n   - wget\n   - unzip\n   - gnupg\n   - ca-certificates\n   - jq\n   - nginx\n\nruncmd: \n   - systemctl enable docker\n   - systemctl start docker\n   - systemctl enable cockpit.socket\n   - systemctl start cockpit.socket\n   - ufw allow 22\n   - ufw allow 9090\n   - ufw allow 80\n   - ufw allow 443\n   - ufw enable\n   - echo 'Install Traefik...'\n   - curl -sL https://raw.githubusercontent.com/traefik/traefik/v2.11/docs/content/reference/static-configuration/file.md -o /etc/traefik/traefik.yml\n   - mkdir -p /etc/traefik\n   - touch /etc/traefik/acme.json\n   - chmod 600 /etc/traefik/acme.json\n   - docker run -d --name=traefik -p 8081:80 -p 443:443 -p 8080:8080 -v /var/run/docker.sock:/var/run/docker.sock -v /etc/traefik:/etc/traefik traefik:v2.11\n\n #cloud-config\ngrowpart:\n  mode: auto\n  devices: ['/']\n  ignore_growroot_disabled: false\n\nresize_rootfs: true\n\n\nfinal_message: \"VM cloudinit_server configurée et prête à l'emploi.\"\n","template":"#cloud-config\n#https://cloudinit.readthedocs.io/en/latest/reference/examples.html\n\nmanage_etc_hosts: true\npackage_update: true\npackage_upgrade: true\n\nhostname: ${hostname}\nfqdn: ${hostname}.devops-infra.local\npreserve_hostname: false\n\nssh_pwauth: ${ssh_pwauth}\nusers: \n   - name: ${username}\n     sudo: ALL=(ALL) NOPASSWD:ALL\n     groups: ${groups}\n     home: /home/${username}\n     shell: ${shell}\n     lock_passwd: ${lock_passwd}\n     passwd: ${user_password}\n     ssh_authorized_keys: \n      ${ssh_authorized_keys}\n    \n\npackages: \n ${packages_to_install}\n\nruncmd: \n ${run_command}\n\n #cloud-config\ngrowpart:\n  mode: auto\n  devices: ['/']\n  ignore_growroot_disabled: false\n\nresize_rootfs: true\n\n\nfinal_message: \"VM ${hostname} configurée et prête à l'emploi.\"\n","vars":{"groups":"users, admin","hostname":"cloudinit_server","lock_passwd":"false","packages_to_install":"  - python3\n   - python3-pip\n   - apache2-utils\n   - vim\n   - docker.io\n   - eatmydata\n   - cockpit\n   - cockpit-machines\n   - fail2ban\n   - ufw\n   - htop\n   - iftop\n   - nmap\n   - net-tools\n   - curl\n   - wget\n   - unzip\n   - gnupg\n   - ca-certificates\n   - jq\n   - nginx","run_command":"  - systemctl enable docker\n   - systemctl start docker\n   - systemctl enable cockpit.socket\n   - systemctl start cockpit.socket\n   - ufw allow 22\n   - ufw allow 9090\n   - ufw allow 80\n   - ufw allow 443\n   - ufw enable\n   - echo 'Install Traefik...'\n   - curl -sL https://raw.githubusercontent.com/traefik/traefik/v2.11/docs/content/reference/static-configuration/file.md -o /etc/traefik/traefik.yml\n   - mkdir -p /etc/traefik\n   - touch /etc/traefik/acme.json\n   - chmod 600 /etc/traefik/acme.json\n   - docker run -d --name=traefik -p 8081:80 -p 443:443 -p 8080:8080 -v /var/run/docker.sock:/var/run/docker.sock -v /etc/traefik:/etc/traefik traefik:v2.11","shell":"/bin/bash","ssh_authorized_keys":" - ssh-rsa  patrick@patrick-ubuntu-legion","ssh_pwauth":"true","user_password":"$6$lVRqiAwCHdiky0Vp$WdiRM0VToJKGPXSvj1ioRirRBYHB7tJADEzPOfRyG1PfVOiR.lmvzPf4n0W5vFxqONqxpcrtYd0hEAxJuT2xX0","username":"patrick"}},"sensitive_attributes":[]}]},{"mode":"managed","type":"libvirt_cloudinit_disk","name":"cloudinit","provider":"provider[\"registry.opentofu.org/dmacvicar/libvirt\"]","instances":[{"schema_version":0,"attributes":{"id":"/var/lib/libvirt/images/cloudinit_server-cloudinit.qcow2;79fb4ec7-a771-4a89-9676-2ced8bfe975d","meta_data":"","name":"cloudinit_server-cloudinit.qcow2","network_config":"","pool":"default","user_data":"#cloud-config\n#https://cloudinit.readthedocs.io/en/latest/reference/examples.html\n\nmanage_etc_hosts: true\npackage_update: true\npackage_upgrade: true\n\nhostname: cloudinit_server\nfqdn: cloudinit_server.devops-infra.local\npreserve_hostname: false\n\nssh_pwauth: true\nusers: \n   - name: patrick\n     sudo: ALL=(ALL) NOPASSWD:ALL\n     groups: users, admin\n     home: /home/patrick\n     shell: /bin/bash\n     lock_passwd: false\n     passwd: $6$lVRqiAwCHdiky0Vp$WdiRM0VToJKGPXSvj1ioRirRBYHB7tJADEzPOfRyG1PfVOiR.lmvzPf4n0W5vFxqONqxpcrtYd0hEAxJuT2xX0\n     ssh_authorized_keys: \n       - ssh-rsa  patrick@patrick-ubuntu-legion\n    \n\npackages: \n   - python3\n   - python3-pip\n   - apache2-utils\n   - vim\n   - docker.io\n   - eatmydata\n   - cockpit\n   - cockpit-machines\n   - fail2ban\n   - ufw\n   - htop\n   - iftop\n   - nmap\n   - net-tools\n   - curl\n   - wget\n   - unzip\n   - gnupg\n   - ca-certificates\n   - jq\n   - nginx\n\nruncmd: \n   - systemctl enable docker\n   - systemctl start docker\n   - systemctl enable cockpit.socket\n   - systemctl start cockpit.socket\n   - ufw allow 22\n   - ufw allow 9090\n   - ufw allow 80\n   - ufw allow 443\n   - ufw